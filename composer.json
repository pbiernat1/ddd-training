{
    "name": "keedosn/ddd-training",
    "description": "Sample app to train DDD",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "monolog/monolog": "^3.10",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Piotr Biernat",
            "email": "piotr1biernat@gmail.com"
        }
    ]
}
